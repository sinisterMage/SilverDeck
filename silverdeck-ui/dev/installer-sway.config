# Nested-sway kiosk config for installer development (make installer-run-kiosk).
# Mirrors the live ISO session, but runs the debug binary against the fake
# engine and adds an exit binding.
output * bg #000000 solid_color
default_border none
focus_follows_mouse no
for_window [app_id="silverdeck-installer"] fullscreen enable
exec env SILVERDECK_FAKE_INSTALL=1 ./target/debug/silverdeck-installer
bindsym Mod4+Shift+q exit

# Nested-sway kiosk config for development (make ui-run-kiosk).
# Mirrors the shipped /etc/silverdeck/sway.config, but runs the debug binary
# with fake games and adds an exit binding.
output * bg #000000 solid_color
default_border none
focus_follows_mouse no
for_window [app_id="silverdeck-ui"] fullscreen enable
exec env SILVERDECK_FAKE_GAMES=1 ./target/debug/silverdeck-ui
bindsym Mod4+Shift+q exit

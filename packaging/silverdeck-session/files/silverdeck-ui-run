#!/usr/bin/env bash
# Keep the console shell alive: restart silverdeck-ui on crash with backoff.
set -u

backoff=1
while true; do
    systemd-cat -t silverdeck-ui /usr/bin/silverdeck-ui
    code=$?
    printf 'silverdeck-ui exited (%s); restarting in %ss\n' "$code" "$backoff" \
        | systemd-cat -t silverdeck-ui -p warning
    sleep "$backoff"
    if [ "$backoff" -lt 30 ]; then backoff=$((backoff * 2)); fi
done

# SilverDeck kiosk compositor config. The UI is the only persistent client;
# games open fullscreen on top of it and focus returns via sway IPC when they
# exit (driven by silverdeck-ui).
xwayland enable

output * bg #000000 solid_color
default_border none
default_floating_border none
focus_follows_mouse no
seat * hide_cursor 3000

exec /usr/bin/silverdeck-ui-run

for_window [app_id="silverdeck-ui"] fullscreen enable
for_window [class="(?i)steam"] fullscreen enable
for_window [app_id="gamescope"] fullscreen enable
# Anything else a launcher opens should also take the whole screen.
for_window [tiling] fullscreen enable

# Debug escape hatches (physical keyboard only).
bindsym Mod4+Shift+Return exec foot
bindsym Mod4+Shift+q kill

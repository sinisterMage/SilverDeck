# Live-ISO installer compositor config. The GUI installer is the only client.
# No xwayland on the live medium (the installer is native Wayland).
xwayland disable

output * bg #000000 solid_color
default_border none
default_floating_border none
focus_follows_mouse no
seat * hide_cursor 3000

exec /usr/local/bin/silverdeck-installer-run

for_window [app_id="silverdeck-installer"] fullscreen enable

# Debug escape hatches (physical keyboard only).
bindsym Mod4+Shift+Return exec foot
bindsym Mod4+Shift+q kill
